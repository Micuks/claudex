#!/usr/bin/env bash
# claudex — Claude Code harness + Codex models via local CLIProxyAPI
#
# Architecture:
#   Claude Code → ANTHROPIC_BASE_URL → CLIProxyAPI → Codex OAuth → GPT models
#
# Install:
#   curl -fsSL https://raw.githubusercontent.com/Micuks/claudex/main/install.sh | bash
#   npm install -g github:Micuks/claudex
#
# Usage:
#   claudex [claude-args...]
#   claudex login [--device]
#   claudex import-auth [path]
#   claudex setup                 # install CLIProxyAPI + write default config
#   claudex proxy start|stop|status|logs
#   claudex models | doctor | version

set -euo pipefail

CLAUDEX_VERSION="0.1.0"
CLAUDEX_REPO="${CLAUDEX_REPO:-Micuks/claudex}"
CLIPROXY_RELEASES="${CLIPROXY_RELEASES:-https://github.com/router-for-me/CLIProxyAPI/releases}"
# Pin by default for reproducibility; override with CLIPROXY_VERSION=latest or a tag
CLIPROXY_VERSION="${CLIPROXY_VERSION:-v7.2.93}"

CLIPROXY_BIN="${CLIPROXY_BIN:-$HOME/.local/bin/cli-proxy-api}"
CLIPROXY_CONFIG="${CLIPROXY_CONFIG:-$HOME/.cli-proxy-api/config.yaml}"
CLIPROXY_AUTH_DIR="${CLIPROXY_AUTH_DIR:-$HOME/.cli-proxy-api}"
CLIPROXY_HOST="${CLIPROXY_HOST:-127.0.0.1}"
CLIPROXY_PORT="${CLIPROXY_PORT:-8317}"
CLIPROXY_API_KEY="${CLIPROXY_API_KEY:-sk-claudex-local}"
CLIPROXY_PID_FILE="${CLIPROXY_PID_FILE:-$HOME/.cli-proxy-api/cliproxy.pid}"
CLIPROXY_LOG_FILE="${CLIPROXY_LOG_FILE:-$HOME/.cli-proxy-api/cliproxy.log}"
CLIPROXY_OPT_DIR="${CLIPROXY_OPT_DIR:-$HOME/.local/opt/cliproxyapi}"

CLAUDEX_MODEL="${CLAUDEX_MODEL:-gpt-5.6-sol}"
CLAUDEX_OPUS_MODEL="${CLAUDEX_OPUS_MODEL:-gpt-5.6-sol}"
CLAUDEX_SONNET_MODEL="${CLAUDEX_SONNET_MODEL:-gpt-5.6-terra}"
CLAUDEX_HAIKU_MODEL="${CLAUDEX_HAIKU_MODEL:-gpt-5.6-luna}"

BASE_URL="http://${CLIPROXY_HOST}:${CLIPROXY_PORT}"

die() { printf 'claudex: %s\n' "$*" >&2; exit 1; }
info() { printf 'claudex: %s\n' "$*" >&2; }

have() { command -v "$1" >/dev/null 2>&1; }

http_get() {
  # usage: http_get URL [extra curl args...]  → stdout
  local url="$1"; shift || true
  if have curl; then
    curl -fsSL "$@" "$url"
  elif have wget; then
    wget -qO- "$@" "$url"
  else
    die "need curl or wget"
  fi
}

http_download() {
  # usage: http_download URL DEST
  local url="$1" dest="$2"
  if have curl; then
    curl -fL --progress-bar -o "$dest" "$url"
  elif have wget; then
    wget -O "$dest" "$url"
  else
    die "need curl or wget"
  fi
}

py() {
  if have python3; then
    python3 "$@"
  elif have python; then
    python "$@"
  else
    die "need python3 (for JSON/JWT helpers)"
  fi
}

detect_asset() {
  local os arch
  os="$(uname -s | tr '[:upper:]' '[:lower:]')"
  arch="$(uname -m)"
  case "$os" in
    darwin) os="darwin" ;;
    linux) os="linux" ;;
    *) die "unsupported OS: $os (need macOS or Linux)" ;;
  esac
  case "$arch" in
    arm64|aarch64) arch="aarch64" ;;
    x86_64|amd64) arch="amd64" ;;
    *) die "unsupported arch: $arch" ;;
  esac
  # Release asset names: CLIProxyAPI_<ver>_<os>_<arch>.tar.gz
  # darwin uses aarch64/amd64; linux same
  printf '%s %s\n' "$os" "$arch"
}

resolve_cliproxy_tag() {
  local tag="$CLIPROXY_VERSION"
  if [[ "$tag" == "latest" ]]; then
    tag="$(http_get https://api.github.com/repos/router-for-me/CLIProxyAPI/releases/latest \
      | py -c 'import sys,json; print(json.load(sys.stdin)["tag_name"])')"
  fi
  printf '%s\n' "$tag"
}

ensure_dirs() {
  mkdir -p "$HOME/.local/bin" "$CLIPROXY_AUTH_DIR" "$CLIPROXY_OPT_DIR" \
    "$(dirname "$CLIPROXY_LOG_FILE")" "$(dirname "$CLIPROXY_PID_FILE")"
}

write_default_config() {
  if [[ -f "$CLIPROXY_CONFIG" ]]; then
    return 0
  fi
  ensure_dirs
  cat >"$CLIPROXY_CONFIG" <<YAML
# Generated by claudex ${CLAUDEX_VERSION}
# Claude Code → CLIProxyAPI → Codex
host: "127.0.0.1"
port: ${CLIPROXY_PORT}

auth-dir: "~/.cli-proxy-api"

api-keys:
  - "${CLIPROXY_API_KEY}"

debug: false
logging-to-file: false
request-retry: 3

remote-management:
  allow-remote: false
  secret-key: ""
  disable-control-panel: true

quota-exceeded:
  switch-project: true
  switch-preview-model: true

routing:
  strategy: "round-robin"
  session-affinity: true
  session-affinity-ttl: "1h"

proxy-url: ""
YAML
  info "wrote default config $CLIPROXY_CONFIG"
}

install_cliproxy() {
  ensure_dirs
  local tag ver os arch asset url tmpdir
  tag="$(resolve_cliproxy_tag)"
  ver="${tag#v}"
  read -r os arch <<<"$(detect_asset)"
  asset="CLIProxyAPI_${ver}_${os}_${arch}.tar.gz"
  url="${CLIPROXY_RELEASES}/download/${tag}/${asset}"
  info "downloading CLIProxyAPI ${tag} (${os}/${arch})..."
  tmpdir="$(mktemp -d)"
  # shellcheck disable=SC2064
  trap "rm -rf '$tmpdir'" RETURN
  http_download "$url" "$tmpdir/$asset"
  tar -xzf "$tmpdir/$asset" -C "$tmpdir"
  local bin
  bin="$(find "$tmpdir" -type f -name 'cli-proxy-api' | head -1)"
  [[ -n "$bin" && -f "$bin" ]] || die "cli-proxy-api not found inside $asset"
  install -m 0755 "$bin" "$CLIPROXY_OPT_DIR/cli-proxy-api"
  ln -sfn "$CLIPROXY_OPT_DIR/cli-proxy-api" "$CLIPROXY_BIN"
  # Also expose under common name
  ln -sfn "$CLIPROXY_OPT_DIR/cli-proxy-api" "$HOME/.local/bin/cliproxyapi"
  info "installed $CLIPROXY_BIN"
}

ensure_path_hint() {
  case ":$PATH:" in
    *":$HOME/.local/bin:"*) ;;
    *)
      info "note: add to PATH →  export PATH=\"\$HOME/.local/bin:\$PATH\""
      ;;
  esac
}

cmd_setup() {
  local force=0
  [[ "${1:-}" == "--force" ]] && force=1
  ensure_dirs
  write_default_config
  if [[ $force -eq 1 || ! -x "$CLIPROXY_BIN" ]]; then
    install_cliproxy
  else
    info "cli-proxy-api already present: $CLIPROXY_BIN (use: claudex setup --force to reinstall)"
  fi
  ensure_path_hint
  info "next: claudex login   # or: claudex import-auth"
  info "then: claudex"
}

require_bin() {
  if [[ ! -x "$CLIPROXY_BIN" ]]; then
    info "cli-proxy-api missing; running setup..."
    cmd_setup
  fi
  if [[ ! -f "$CLIPROXY_CONFIG" ]]; then
    write_default_config
  fi
  [[ -x "$CLIPROXY_BIN" ]] || die "cli-proxy-api still missing after setup"
}

proxy_listening() {
  if have curl; then
    curl -fsS --max-time 1 "${BASE_URL}/v1/models" \
      -H "Authorization: Bearer ${CLIPROXY_API_KEY}" >/dev/null 2>&1
  elif have wget; then
    wget -qO- --timeout=1 \
      --header="Authorization: Bearer ${CLIPROXY_API_KEY}" \
      "${BASE_URL}/v1/models" >/dev/null 2>&1
  else
    return 1
  fi
}

proxy_pid() {
  if [[ -f "$CLIPROXY_PID_FILE" ]]; then
    local pid
    pid="$(cat "$CLIPROXY_PID_FILE" 2>/dev/null || true)"
    if [[ -n "${pid:-}" ]] && kill -0 "$pid" 2>/dev/null; then
      printf '%s\n' "$pid"
      return 0
    fi
  fi
  if have lsof; then
    lsof -nP -iTCP:"$CLIPROXY_PORT" -sTCP:LISTEN -t 2>/dev/null | head -1 || true
  elif have ss; then
    ss -lptn "sport = :$CLIPROXY_PORT" 2>/dev/null \
      | sed -n 's/.*pid=\([0-9]*\).*/\1/p' | head -1 || true
  fi
}

cmd_proxy_start() {
  require_bin
  if proxy_listening; then
    info "proxy already up at ${BASE_URL} (pid $(proxy_pid || echo '?'))"
    return 0
  fi
  ensure_dirs
  nohup "$CLIPROXY_BIN" -config "$CLIPROXY_CONFIG" \
    >>"$CLIPROXY_LOG_FILE" 2>&1 &
  local pid=$!
  printf '%s\n' "$pid" >"$CLIPROXY_PID_FILE"
  local i
  for i in $(seq 1 50); do
    if proxy_listening; then
      info "proxy started pid=$pid ${BASE_URL}"
      return 0
    fi
    if ! kill -0 "$pid" 2>/dev/null; then
      die "proxy exited early; see $CLIPROXY_LOG_FILE"
    fi
    sleep 0.15
  done
  die "proxy did not become ready; see $CLIPROXY_LOG_FILE"
}

cmd_proxy_stop() {
  local pid
  pid="$(proxy_pid || true)"
  if [[ -z "${pid:-}" ]]; then
    info "proxy not running"
    rm -f "$CLIPROXY_PID_FILE"
    return 0
  fi
  kill "$pid" 2>/dev/null || true
  local i
  for i in $(seq 1 30); do
    if ! kill -0 "$pid" 2>/dev/null; then
      rm -f "$CLIPROXY_PID_FILE"
      info "proxy stopped (was pid $pid)"
      return 0
    fi
    sleep 0.1
  done
  kill -9 "$pid" 2>/dev/null || true
  rm -f "$CLIPROXY_PID_FILE"
  info "proxy force-stopped (pid $pid)"
}

cmd_proxy_status() {
  local pid
  pid="$(proxy_pid || true)"
  if proxy_listening; then
    info "UP  ${BASE_URL}  pid=${pid:-?}  key=${CLIPROXY_API_KEY}"
    return 0
  fi
  if [[ -n "${pid:-}" ]]; then
    info "DOWN (process pid=$pid present but /v1/models not responding)"
    return 1
  fi
  info "DOWN  ${BASE_URL}"
  return 1
}

cmd_proxy_logs() {
  [[ -f "$CLIPROXY_LOG_FILE" ]] || die "no log file at $CLIPROXY_LOG_FILE"
  exec tail -n "${1:-80}" -f "$CLIPROXY_LOG_FILE"
}

cmd_login() {
  require_bin
  local mode="${1:-}"
  if [[ "$mode" == "--device" || "$mode" == "device" ]]; then
    info "starting Codex device-code login..."
    exec "$CLIPROXY_BIN" -config "$CLIPROXY_CONFIG" -codex-device-login
  fi
  info "starting Codex OAuth login (browser)..."
  exec "$CLIPROXY_BIN" -config "$CLIPROXY_CONFIG" -codex-login
}

cmd_import_auth() {
  local src="${1:-$HOME/.codex/auth.json}"
  [[ -f "$src" ]] || die "missing Codex auth: $src (run: codex login, then claudex import-auth)"
  mkdir -p "$CLIPROXY_AUTH_DIR"
  py - "$src" "$CLIPROXY_AUTH_DIR" <<'PY'
import json, base64, pathlib, re, sys
from datetime import datetime, timezone

src, dst_dir = pathlib.Path(sys.argv[1]), pathlib.Path(sys.argv[2])
d = json.loads(src.read_text())
tokens = d.get("tokens") or {}
access = tokens.get("access_token") or ""
refresh = tokens.get("refresh_token") or ""
id_token = tokens.get("id_token") or ""
account_id = tokens.get("account_id") or ""
last_refresh = d.get("last_refresh") or ""

def b64url_json(seg: str):
    pad = "=" * (-len(seg) % 4)
    return json.loads(base64.urlsafe_b64decode(seg + pad))

email, plan, exp = "codex-user", "", ""
try:
    claims = b64url_json(id_token.split(".")[1])
    email = claims.get("email") or claims.get("preferred_username") or email
    auth_claims = claims.get("https://api.openai.com/auth") or {}
    if isinstance(auth_claims, dict):
        plan = auth_claims.get("chatgpt_plan_type") or auth_claims.get("plan_type") or ""
        account_id = account_id or auth_claims.get("chatgpt_account_id") or ""
    if claims.get("exp"):
        exp = datetime.fromtimestamp(int(claims["exp"]), tz=timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
except Exception as e:
    print(f"jwt parse warn: {e}", file=sys.stderr)

def slug(s: str) -> str:
    s = re.sub(r"[^A-Za-z0-9._@+-]+", "-", (s or "").strip())
    return s.strip("-") or "user"

hash_part = slug(account_id)[:16] if account_id else "local"
email_part = slug(email)
plan_part = slug(plan)
name = f"codex-{hash_part}-{email_part}" + (f"-{plan_part}" if plan_part else "") + ".json"

out = {
    "type": "codex",
    "id_token": id_token,
    "access_token": access,
    "refresh_token": refresh,
    "account_id": account_id,
    "last_refresh": last_refresh or datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
    "email": email,
}
if exp:
    out["expired"] = exp

path = dst_dir / name
for old in dst_dir.glob("codex-*.json"):
    try:
        od = json.loads(old.read_text())
        if od.get("email") == email and old != path:
            old.unlink()
    except Exception:
        pass
path.write_text(json.dumps(out, indent=2) + "\n")
path.chmod(0o600)
print(f"wrote {path}")
print(f"email={email} plan={plan or '-'} expired={exp or '-'} has_refresh={bool(refresh)}")
PY
}

cmd_models() {
  cmd_proxy_start
  if have curl; then
    curl -fsS "${BASE_URL}/v1/models" \
      -H "Authorization: Bearer ${CLIPROXY_API_KEY}" \
      -H "Content-Type: application/json"
  else
    wget -qO- --header="Authorization: Bearer ${CLIPROXY_API_KEY}" \
      "${BASE_URL}/v1/models"
  fi | py -c '
import json,sys
d=json.load(sys.stdin)
data=d.get("data") or d.get("models") or []
ids=[]
for m in data:
    if isinstance(m, dict):
        ids.append(m.get("id") or m.get("name") or str(m))
    else:
        ids.append(str(m))
for i in sorted(set(ids)):
    print(i)
print(f"\n# {len(set(ids))} models", file=sys.stderr)
'
}

cmd_doctor() {
  echo "claudex $CLAUDEX_VERSION"
  echo
  echo "== binary =="
  if [[ -x "$CLIPROXY_BIN" ]]; then
    "$CLIPROXY_BIN" -h 2>&1 | head -1 || true
    echo "bin: $CLIPROXY_BIN OK"
  else
    echo "bin: MISSING $CLIPROXY_BIN (run: claudex setup)"
  fi
  echo
  echo "== config =="
  echo "config: $CLIPROXY_CONFIG $([ -f "$CLIPROXY_CONFIG" ] && echo OK || echo MISSING)"
  echo "auth-dir: $CLIPROXY_AUTH_DIR"
  ls -la "$CLIPROXY_AUTH_DIR"/codex-*.json 2>/dev/null || echo "  (no codex-*.json — run: claudex login  or  claudex import-auth)"
  echo
  echo "== proxy =="
  cmd_proxy_status || true
  if proxy_listening; then
    echo
    echo "== sample models =="
    cmd_models 2>/dev/null | head -20 || true
  fi
  echo
  echo "== claude =="
  if have claude; then
    echo "claude: $(command -v claude)"
    claude --version 2>&1 | head -3 || true
  else
    echo "claude: NOT FOUND in PATH  (npm i -g @anthropic-ai/claude-code)"
  fi
  echo
  echo "== defaults =="
  echo "model=$CLAUDEX_MODEL opus=$CLAUDEX_OPUS_MODEL sonnet=$CLAUDEX_SONNET_MODEL haiku=$CLAUDEX_HAIKU_MODEL"
  echo "base_url=$BASE_URL auth_token=$CLIPROXY_API_KEY"
}

has_codex_auth() {
  # portable glob check without bash-only compgen when possible
  local f
  for f in "$CLIPROXY_AUTH_DIR"/codex-*.json; do
    [[ -f "$f" ]] && return 0
  done
  return 1
}

cmd_run_claude() {
  require_bin
  if ! have claude; then
    die "claude not found in PATH
Install Claude Code:  npm i -g @anthropic-ai/claude-code"
  fi

  if ! has_codex_auth; then
    if [[ -f "$HOME/.codex/auth.json" ]]; then
      info "no CLIProxyAPI Codex auth; importing from ~/.codex/auth.json"
      cmd_import_auth
    else
      die "no Codex credentials. Run: claudex login"
    fi
  fi

  cmd_proxy_start

  export ANTHROPIC_BASE_URL="$BASE_URL"
  export ANTHROPIC_AUTH_TOKEN="$CLIPROXY_API_KEY"
  unset ANTHROPIC_API_KEY 2>/dev/null || true

  export ANTHROPIC_MODEL="$CLAUDEX_MODEL"
  export ANTHROPIC_DEFAULT_OPUS_MODEL="$CLAUDEX_OPUS_MODEL"
  export ANTHROPIC_DEFAULT_SONNET_MODEL="$CLAUDEX_SONNET_MODEL"
  export ANTHROPIC_DEFAULT_HAIKU_MODEL="$CLAUDEX_HAIKU_MODEL"
  export ANTHROPIC_SMALL_FAST_MODEL="$CLAUDEX_HAIKU_MODEL"
  export CLAUDE_CODE_SUBAGENT_MODEL="${CLAUDE_CODE_SUBAGENT_MODEL:-$CLAUDEX_SONNET_MODEL}"

  export CLAUDE_CODE_ALWAYS_ENABLE_EFFORT="${CLAUDE_CODE_ALWAYS_ENABLE_EFFORT:-1}"
  export ENABLE_TOOL_SEARCH="${ENABLE_TOOL_SEARCH:-false}"
  export CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY="${CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY:-3}"

  info "Claude Code → CLIProxyAPI(${BASE_URL}) → Codex  model=${CLAUDEX_MODEL}"
  exec claude --model "$CLAUDEX_MODEL" "$@"
}

usage() {
  cat <<EOF
claudex ${CLAUDEX_VERSION} — Claude Code harness powered by Codex via CLIProxyAPI

  claudex [args...]              launch Claude Code (default: ${CLAUDEX_MODEL})
  claudex setup [--force]        install CLIProxyAPI + write config
  claudex login [--device]       Codex OAuth / device-code login
  claudex import-auth [path]     import ~/.codex/auth.json
  claudex proxy start|stop|status|logs
  claudex models                 list proxy models
  claudex doctor                 diagnostics
  claudex version

Install on a new machine:
  curl -fsSL https://raw.githubusercontent.com/${CLAUDEX_REPO}/main/install.sh | bash
  npm install -g github:${CLAUDEX_REPO}

Model overrides (env):
  CLAUDEX_MODEL  CLAUDEX_OPUS_MODEL  CLAUDEX_SONNET_MODEL  CLAUDEX_HAIKU_MODEL
EOF
}

main() {
  local cmd="${1:-}"
  case "$cmd" in
    -h|--help|help) usage; exit 0 ;;
    -V|--version|version) echo "claudex $CLAUDEX_VERSION"; exit 0 ;;
    setup)
      shift
      cmd_setup "${1:-}"
      ;;
    login)
      shift
      cmd_login "${1:-}"
      ;;
    import-auth)
      shift
      cmd_import_auth "${1:-}"
      ;;
    proxy)
      shift
      case "${1:-}" in
        start) cmd_proxy_start ;;
        stop) cmd_proxy_stop ;;
        status) cmd_proxy_status ;;
        logs) shift; cmd_proxy_logs "${1:-80}" ;;
        *) die "usage: claudex proxy start|stop|status|logs" ;;
      esac
      ;;
    models) cmd_models ;;
    doctor) cmd_doctor ;;
    "")
      cmd_run_claude
      ;;
    *)
      cmd_run_claude "$@"
      ;;
  esac
}

main "$@"
